<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ovella — Earlier Answers. Real Relief. Long-Term Support.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  : root {
    --rose: #C01E5C;
    --rose-light: #E8526A;
    --blush: #FFF0F3;
    --blush-mid: #F9DDE5;
    --cream: #FDF8F5;
    --charcoal: #1A1018;
    --muted: #7A6070;
    --white: #FFFFFF;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--charcoal);
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.25rem 3rem;
    background: rgba(253,248,245,0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(192,30,92,0.1);
  }
  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem; font-weight: 600; color: var(--rose);
    text-decoration: none; letter-spacing: 0.04em;
    display: flex; align-items: center; gap: 0.5rem;
  }
  .nav-logo svg { width: 26px; height: 26px; }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    text-decoration: none; color: var(--muted); font-size: 0.88rem;
    font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--rose); }
  .nav-cta {
    background: var(--rose); color: white !important;
    padding: 0.55rem 1.4rem; border-radius: 100px;
    font-size: 0.82rem !important; font-weight: 500 !important;
    transition: background 0.2s, transform 0.15s !important;
  }
  .nav-cta:hover { background: var(--rose-light) !important; transform: translateY(-1px); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: grid; grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 8rem 3rem 4rem;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; top: -10%; right: -5%;
    width: 55%; height: 110%;
    background: radial-gradient(ellipse at 60% 40%, #f9c7d6 0%, #fde8ee 45%, transparent 75%);
    z-index: 0; border-radius: 60% 40% 50% 50% / 50% 50% 40% 60%;
  }
  .hero-text { position: relative; z-index: 1; max-width: 560px; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--blush-mid); color: var(--rose);
    font-size: 0.75rem; font-weight: 500; letter-spacing: 0.1em;
    text-transform: uppercase; padding: 0.4rem 1rem; border-radius: 100px;
    margin-bottom: 2rem;
  }
  .hero-badge span { width: 6px; height: 6px; background: var(--rose); border-radius: 50%; }
  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 5.5vw, 5.5rem);
    font-weight: 300; line-height: 1.08;
    color: var(--charcoal); margin-bottom: 1.5rem;
  }
  .hero h1 em { color: var(--rose); font-style: italic; }
  .hero p {
    font-size: 1.05rem; color: var(--muted); line-height: 1.75;
    margin-bottom: 2.5rem; max-width: 440px;
  }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; }
  .btn-primary {
    background: var(--rose); color: white;
    padding: 0.9rem 2rem; border-radius: 100px;
    font-size: 0.9rem; font-weight: 500; text-decoration: none;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(192,30,92,0.35);
  }
  .btn-primary:hover { background: var(--rose-light); transform: translateY(-2px); box-shadow: 0 8px 30px rgba(192,30,92,0.4); }
  .btn-secondary {
    color: var(--rose); font-size: 0.9rem; font-weight: 500;
    text-decoration: none; display: flex; align-items: center; gap: 0.4rem;
    transition: gap 0.2s;
  }
  .btn-secondary:hover { gap: 0.7rem; }
  .hero-stats {
    display: flex; gap: 2.5rem; margin-top: 3.5rem;
    padding-top: 2.5rem; border-top: 1px solid var(--blush-mid);
  }
  .stat-val {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem; font-weight: 500; color: var(--rose); line-height: 1;
  }
  .stat-label { font-size: 0.78rem; color: var(--muted); margin-top: 0.3rem; line-height: 1.4; }

  .hero-visual { position: relative; z-index: 1; display: flex; justify-content: center; align-items: center; }
  .hero-device {
    width: 300px; height: 360px;
    background: linear-gradient(145deg, #fff 0%, #fde8ee 100%);
    border-radius: 50% 50% 45% 45% / 55% 55% 45% 45%;
    box-shadow: 0 30px 80px rgba(192,30,92,0.18), 0 8px 30px rgba(0,0,0,0.06);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 1.2rem; position: relative; overflow: hidden;
  }
  .hero-device::after {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.6) 0%, transparent 60%);
  }
  .device-icon { font-size: 3.5rem; }
  .device-label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem; color: var(--rose); font-weight: 500; text-align: center;
  }
  .device-sub { font-size: 0.78rem; color: var(--muted); text-align: center; }
  .floating-badge {
    position: absolute;
    background: white; border-radius: 12px;
    padding: 0.7rem 1rem; box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    font-size: 0.78rem; font-weight: 500;
  }
  .badge-ai { top: -10px; right: -30px; color: var(--rose); }
  .badge-fda { bottom: 20px; left: -40px; color: var(--muted); }
  .badge-users { top: 50%; right: -50px; color: var(--charcoal); }
  .badge-dot { width: 8px; height: 8px; border-radius: 50%; background: #22c55e; display: inline-block; margin-right: 4px; }

  /* ── SECTION SHARED ── */
  section { padding: 6rem 3rem; }
  .section-label {
    font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--rose); font-weight: 500; margin-bottom: 0.8rem;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 300; line-height: 1.15; color: var(--charcoal);
  }
  .section-title em { color: var(--rose); font-style: italic; }

  /* ── PROBLEM ── */
  .problem {
    background: var(--charcoal);
    position: relative; overflow: hidden;
  }
  .problem::before {
    content: '';
    position: absolute; bottom: -20%; left: -10%;
    width: 60%; height: 140%;
    background: radial-gradient(ellipse, rgba(192,30,92,0.2) 0%, transparent 70%);
  }
  .problem .inner { position: relative; z-index: 1; max-width: 1100px; margin: 0 auto; }
  .problem .section-title { color: white; }
  .problem .section-label { color: var(--rose-light); }
  .problem p { color: rgba(255,255,255,0.65); font-size: 1.05rem; line-height: 1.8; max-width: 600px; margin: 1.5rem 0 3rem; }
  .prob-cards {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  }
  .prob-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px; padding: 2rem;
    transition: background 0.2s, transform 0.2s;
  }
  .prob-card:hover { background: rgba(255,255,255,0.08); transform: translateY(-3px); }
  .prob-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem; color: var(--rose); font-weight: 300; line-height: 1;
  }
  .prob-card h3 { color: white; font-size: 0.95rem; font-weight: 500; margin: 0.8rem 0 0.5rem; }
  .prob-card p { color: rgba(255,255,255,0.5); font-size: 0.85rem; line-height: 1.6; margin: 0; }

  /* ── SOLUTION ── */
  .solution { background: var(--blush); }
  .solution .inner { max-width: 1100px; margin: 0 auto; }
  .solution-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 5rem;
    align-items: center; margin-top: 3.5rem;
  }
  .mech-list { display: flex; flex-direction: column; gap: 2rem; }
  .mech-item {
    display: grid; grid-template-columns: 56px 1fr; gap: 1.2rem;
    align-items: start; cursor: default;
    padding: 1.5rem; border-radius: 14px;
    transition: background 0.2s;
  }
  .mech-item:hover { background: rgba(192,30,92,0.05); }
  .mech-icon {
    width: 52px; height: 52px; border-radius: 14px;
    background: var(--rose); display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; flex-shrink: 0;
  }
  .mech-item h3 { font-size: 1rem; font-weight: 600; color: var(--charcoal); margin-bottom: 0.4rem; }
  .mech-item p { font-size: 0.88rem; color: var(--muted); line-height: 1.7; }
  .solution-visual {
    background: white; border-radius: 24px;
    padding: 2.5rem; box-shadow: 0 20px 60px rgba(0,0,0,0.07);
  }
  .sv-header { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 500; margin-bottom: 1.5rem; color: var(--charcoal); }
  .sv-row { display: flex; align-items: center; gap: 1rem; padding: 0.9rem 0; border-bottom: 1px solid #f0e8ec; }
  .sv-row:last-child { border-bottom: none; }
  .sv-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .sv-label { font-size: 0.85rem; color: var(--muted); flex: 1; }
  .sv-val { font-size: 0.85rem; font-weight: 600; color: var(--rose); }
  .sv-bar-wrap { flex: 1; height: 6px; background: #f0e8ec; border-radius: 3px; overflow: hidden; }
  .sv-bar { height: 100%; background: var(--rose); border-radius: 3px; }

  /* ── HOW IT WORKS ── */
  .how { background: white; }
  .how .inner { max-width: 1100px; margin: 0 auto; }
  .how-steps {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 2rem; margin-top: 3.5rem;
  }
  .step {
    padding: 2.5rem 2rem; border: 1px solid #f0e8ec; border-radius: 20px;
    position: relative; transition: box-shadow 0.2s, transform 0.2s;
  }
  .step:hover { box-shadow: 0 16px 48px rgba(192,30,92,0.1); transform: translateY(-4px); }
  .step-num {
    position: absolute; top: -1px; left: 2rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 5rem; font-weight: 300; color: rgba(192,30,92,0.08);
    line-height: 1; pointer-events: none;
  }
  .step-title { font-size: 1.05rem; font-weight: 600; margin-bottom: 0.8rem; position: relative; z-index: 1; }
  .step p { font-size: 0.87rem; color: var(--muted); line-height: 1.75; position: relative; z-index: 1; }
  .step-tag {
    display: inline-block; margin-top: 1.2rem;
    background: var(--blush-mid); color: var(--rose);
    font-size: 0.72rem; font-weight: 500; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 0.3rem 0.8rem; border-radius: 100px;
  }

  /* ── COMPARISON ── */
  .compare { background: var(--cream); }
  .compare .inner { max-width: 1100px; margin: 0 auto; }
  .compare-intro { max-width: 560px; margin-bottom: 3.5rem; }
  .compare-intro p { color: var(--muted); line-height: 1.75; margin-top: 1rem; }
  .compare-table { width: 100%; border-collapse: collapse; }
  .compare-table th {
    text-align: left; font-size: 0.75rem; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--muted); font-weight: 500;
    padding: 0.75rem 1.2rem; border-bottom: 2px solid #f0e8ec;
  }
  .compare-table td {
    padding: 1rem 1.2rem; border-bottom: 1px solid #f0e8ec;
    font-size: 0.88rem;
  }
  .compare-table tr.ov-row td { background: #fff5f8; }
  .compare-table tr.ov-row td:first-child { font-weight: 700; color: var(--rose); border-left: 3px solid var(--rose); }
  .check { color: var(--rose); font-size: 1.1rem; }
  .cross { color: #ccc; font-size: 1.1rem; }
  .price-cell { font-weight: 600; color: var(--charcoal); }
  .price-cell.ov { color: var(--rose); }

  /* ── MARKET ── */
  .market { background: var(--blush); }
  .market .inner { max-width: 1100px; margin: 0 auto; }
  .market-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; margin-top: 3.5rem; }
  .market p { color: var(--muted); line-height: 1.8; margin-top: 1rem; }
  .tam-rings {
    display: flex; flex-direction: column; gap: 1.2rem;
  }
  .tam-ring {
    border-radius: 14px; padding: 1.4rem 1.8rem;
    display: flex; justify-content: space-between; align-items: center;
  }
  .tam-ring.a { background: var(--rose); }
  .tam-ring.b { background: rgba(192,30,92,0.55); }
  .tam-ring.c { background: rgba(192,30,92,0.3); }
  .tam-ring-label { color: white; font-size: 0.8rem; font-weight: 500; opacity: 0.85; }
  .tam-ring-val { font-family: 'Cormorant Garamond', serif; color: white; font-size: 1.8rem; font-weight: 500; }
  .tam-ring-sub { color: rgba(255,255,255,0.7); font-size: 0.72rem; margin-top: 0.1rem; }

  /* ── VALIDATION ── */
  .validation { background: white; }
  .validation .inner { max-width: 1100px; margin: 0 auto; }
  .val-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 2rem; margin-top: 3.5rem; }
  .val-card {
    background: var(--blush); border-radius: 20px; padding: 2rem;
    transition: transform 0.2s;
  }
  .val-card:hover { transform: translateY(-4px); }
  .val-big {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.5rem; font-weight: 300; color: var(--rose); line-height: 1;
  }
  .val-card h3 { font-size: 0.95rem; font-weight: 600; margin: 0.7rem 0 0.4rem; }
  .val-card p { font-size: 0.84rem; color: var(--muted); line-height: 1.65; }

  /* ── TEAM ── */
  .team { background: var(--cream); }
  .team .inner { max-width: 1100px; margin: 0 auto; }
  .team-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 3.5rem; max-width: 600px; }
  .team-card {
    background: white; border-radius: 20px; padding: 2rem;
    border: 1px solid #f0e8ec; transition: box-shadow 0.2s;
  }
  .team-card:hover { box-shadow: 0 12px 40px rgba(192,30,92,0.1); }
  .team-avatar {
    width: 64px; height: 64px; border-radius: 50%;
    background: linear-gradient(135deg, var(--rose), var(--rose-light));
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif; font-size: 1.5rem;
    color: white; font-weight: 500; margin-bottom: 1rem;
  }
  .team-name { font-size: 1rem; font-weight: 600; }
  .team-role { font-size: 0.8rem; color: var(--rose); margin: 0.2rem 0 0.7rem; font-weight: 500; }
  .team-card p { font-size: 0.84rem; color: var(--muted); line-height: 1.65; }

  /* ── CTA ── */
  .cta-section {
    background: var(--charcoal);
    text-align: center; padding: 7rem 3rem;
    position: relative; overflow: hidden;
  }
  .cta-section::before {
    content: '';
    position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(192,30,92,0.25) 0%, transparent 70%);
  }
  .cta-section .section-label { color: var(--rose-light); }
  .cta-section h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 300; color: white; margin: 0.8rem 0 1.5rem; line-height: 1.1;
    position: relative; z-index: 1;
  }
  .cta-section h2 em { color: var(--rose-light); font-style: italic; }
  .cta-section p { color: rgba(255,255,255,0.55); font-size: 1rem; max-width: 480px; margin: 0 auto 2.5rem; line-height: 1.75; position: relative; z-index: 1; }
  .cta-group { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; position: relative; z-index: 1; }
  .btn-white {
    background: white; color: var(--rose);
    padding: 0.9rem 2rem; border-radius: 100px;
    font-size: 0.9rem; font-weight: 600; text-decoration: none;
    transition: transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }
  .btn-white:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,0,0,0.3); }
  .btn-ghost {
    border: 1px solid rgba(255,255,255,0.25); color: rgba(255,255,255,0.85);
    padding: 0.9rem 2rem; border-radius: 100px;
    font-size: 0.9rem; font-weight: 500; text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover { border-color: rgba(255,255,255,0.6); color: white; }

  /* ── FOOTER ── */
  footer {
    background: var(--charcoal); border-top: 1px solid rgba(255,255,255,0.07);
    padding: 2rem 3rem; display: flex; justify-content: space-between; align-items: center;
  }
  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem; color: rgba(255,255,255,0.4); font-weight: 400;
  }
  footer p { color: rgba(255,255,255,0.25); font-size: 0.78rem; }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  .hero-text > * { animation: fadeUp 0.7s ease both; }
  .hero-badge { animation-delay: 0.1s; }
  .hero h1 { animation-delay: 0.2s; }
  .hero p { animation-delay: 0.35s; }
  .hero-actions { animation-delay: 0.5s; }
  .hero-stats { animation-delay: 0.65s; }
  .hero-device { animation: float 5s ease-in-out infinite; }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    .hero { grid-template-columns: 1fr; padding: 7rem 1.5rem 3rem; }
    .hero-visual { display: none; }
    section { padding: 4rem 1.5rem; }
    .prob-cards, .how-steps, .val-grid { grid-template-columns: 1fr; }
    .solution-grid, .market-grid, .team-grid { grid-template-columns: 1fr; }
    .hero-stats { flex-wrap: wrap; gap: 1.5rem; }
  }
</style>
</head>
